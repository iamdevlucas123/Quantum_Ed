{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@quantum-ed/shared-types": ["../packages/shared/types/index.d.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    "prisma.config.ts",
    "../packages/shared/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
