# Build stage
FROM node:20-slim AS builder

WORKDIR /api

COPY package*.json ./
RUN npm install

COPY . .

# Compile TypeScript
RUN npm run build

# Production stage 
FROM node:20-slim

WORKDIR /api

# Copy only necessary files
COPY package*.json ./
RUN npm install --omit=dev

# Copy compiled output from builder
COPY --from=builder /api/dist ./dist

EXPOSE 3000

CMD ["node", "dist/server.js"]